{
  "manifest_version": 3,
  "name": "VMD Viewer",
  "description": "Render VMD files as semantic visual webpages.",
  "version": "0.1.0",
  "action": {
    "default_title": "Open VMD Viewer",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "file:///*"
  ],
  "content_scripts": [
    {
      "matches": [
        "file:///*",
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "vmd-core.js",
        "auto-render.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
