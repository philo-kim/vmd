{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vmd.dev/schemas/vmd-ast.schema.json",
  "title": "VMD AST",
  "type": "object",
  "required": ["type", "doc", "children"],
  "properties": {
    "type": {
      "const": "document"
    },
    "doc": {
      "type": "object",
      "required": ["title", "attrs"],
      "properties": {
        "title": {
          "type": "string"
        },
        "attrs": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "children": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "node": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        },
        "variant": {
          "type": ["string", "null"]
        },
        "attrs": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "lines": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/node"
          }
        },
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "level": {
          "type": "integer",
          "minimum": 1,
          "maximum": 6
        },
        "text": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
